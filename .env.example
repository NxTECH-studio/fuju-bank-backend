# 本番デプロイ（compose.prod.yml）およびサーバー側での手動 docker compose 実行で使う環境変数のテンプレート。
# `cp .env.example .env` して実値を埋める。GitHub Secrets/Variables にも同じ値を登録すること。
# 開発環境（compose.yml）ではこのファイルは使用しない。

# config/master.key と一致させる
RAILS_MASTER_KEY=

# postgres superuser のパスワード。初回 initdb で PGDATA に焼き付くので、後から変える場合は volume 削除が必要
FUJU_BANK_BACKEND_DATABASE_PASSWORD=

# Rails の host authorization 用。カンマ区切りで複数指定可（例: bank.fuju.example.com,api.fuju.example.com）
ALLOWED_HOSTS=
